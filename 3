async def trading_loop(_: Application) -> None:
    logger.info("Trading loop started with Cumulative Fee Recovery")
    await send_telegram("Bot started • Cumulative Fee + Loss Recovery", silent=False)

    while True:
        if not monitored_symbols:
            await asyncio.sleep(CHECK_INTERVAL_SECONDS)
            continue

        for symbol in list(monitored_symbols):
            try:
                sync_position_state(symbol)
                current_side = symbol_position_state.get(symbol)
                mark_price = get_current_price(symbol)
                qty = calculate_safe_quantity(symbol)
                if qty < 1e-5: continue

                klines_8h = get_klines(symbol, "8h", limit=5)
                if len(klines_8h) < 2: continue
                current_candle_open_ts = int(klines_8h[-1][0]) / 1000.0
                day_open = float(klines_8h[-1][1])

                if symbol_candle_open_time.get(symbol, 0) != current_candle_open_ts:
                    symbol_candle_open_time[symbol] = current_candle_open_ts
                    symbol_blocked_until_candle.pop(symbol, None)
                    symbol_tp_order_id.pop(symbol, None)
                    symbol_cumulative_realized_loss[symbol] = 0.0
                    symbol_realized_pnl_this_candle[symbol] = 0.0
                    symbol_entry_count_this_candle[symbol] = 0

                now_ts = time.time()
                if now_ts < symbol_blocked_until_candle.get(symbol, 0):
                    continue

                if now_ts - current_candle_open_ts < 60: continue
                if current_candle_open_ts < symbol_tradeable_from_candle.get(symbol, 0) - 10: continue

                if current_side is None and (now_ts - symbol_last_entry_time.get(symbol, 0) < COOLDOWN_SECONDS):
                    continue

                realized_pnl = get_realized_pnl_this_candle(symbol, current_candle_open_ts)
                symbol_realized_pnl_this_candle[symbol] = realized_pnl

                notional = qty * mark_price
                profit_threshold = (PROFIT_LOCK_PCT / 100.0) * notional

                if realized_pnl >= profit_threshold and current_side is not None:
                    close_position(symbol, f"{PROFIT_LOCK_PCT}% profit lock")
                    symbol_blocked_until_candle[symbol] = current_candle_open_ts + 8 * 3600
                    await send_telegram(f"🔒 Profit Lock {symbol}\nBlocked this candle", silent=False)
                    continue

                # ==================== CUMULATIVE FEE LOGIC ====================
                current_loss = max(0.0, -realized_pnl)
                loss_pct = (current_loss / notional * 100) if notional > 0 else 0.0

                entry_count = symbol_entry_count_this_candle.get(symbol, 1)
                total_fee_pct = entry_count * FEE_PER_ROUNDTRIP

                dynamic_tp = BASE_TP_PCT + total_fee_pct + loss_pct

                logger.info(f"[{symbol}] Entry #{entry_count} | Loss: {loss_pct:.3f}% | Fees: {total_fee_pct:.3f}% | TP: {dynamic_tp:.3f}%")

                # SMA with pandas_ta
                klines_1m = get_klines(symbol, "1m", limit=100)
                if len(klines_1m) < 20: continue
                df = pd.DataFrame(klines_1m, columns=['ts','open','high','low','close','vol','close_time',
                                                      'qvol','trades','taker_base','taker_quote','ignore'])
                df['close'] = pd.to_numeric(df['close'])
                df['sma3'] = ta.sma(df['close'], length=3)

                sma_current = df['sma3'].iloc[-2]
                sma_prev = df['sma3'].iloc[-3] if len(df) > 1 else sma_current

                in_safety = (now_ts - symbol_last_exit_time.get(symbol, 0)) < 8

                # ==================== ENTRY ====================
                if current_side is None and not in_safety:
                    wait_for = symbol_wait_for_reversal.get(symbol)

                    if sma_current > day_open and sma_prev < day_open and (wait_for is None or wait_for == "SHORT"):
                        resp = place_market_order(symbol, "BUY", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_entry_count_this_candle[symbol] = entry_count + 1
                            await asyncio.sleep(1.0)
                            sync_position_state(symbol)
                            pos = get_current_position_data(symbol)
                            actual_entry = float(pos.get("entryPrice", mark_price))
                            
                            symbol_position_state[symbol] = "LONG"
                            symbol_entry_price[symbol] = actual_entry
                            symbol_last_entry_time[symbol] = now_ts
                            symbol_wait_for_reversal[symbol] = None
                            
                            await send_telegram(f"🟢 LONG {symbol} @ {actual_entry:.4f} | TP: {dynamic_tp:.3f}%", silent=False)
                            cancel_all_orders(symbol)
                            place_take_profit_order(symbol, "BUY", actual_entry, dynamic_tp, qty)

                    elif sma_current < day_open and sma_prev > day_open and (wait_for is None or wait_for == "LONG"):
                        resp = place_market_order(symbol, "SELL", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_entry_count_this_candle[symbol] = entry_count + 1
                            await asyncio.sleep(1.0)
                            sync_position_state(symbol)
                            pos = get_current_position_data(symbol)
                            actual_entry = float(pos.get("entryPrice", mark_price))
                            
                            symbol_position_state[symbol] = "SHORT"
                            symbol_entry_price[symbol] = actual_entry
                            symbol_last_entry_time[symbol] = now_ts
                            symbol_wait_for_reversal[symbol] = None
                            
                            await send_telegram(f"🔴 SHORT {symbol} @ {actual_entry:.4f} | TP: {dynamic_tp:.3f}%", silent=False)
                            cancel_all_orders(symbol)
                            place_take_profit_order(symbol, "SELL", actual_entry, dynamic_tp, qty)

                # ==================== EXIT ====================
                elif current_side is not None:
                    pos = get_current_position_data(symbol)
                    amt = float(pos.get("positionAmt", 0))

                    if abs(amt) < POSITION_TOLERANCE:
                        is_tp = was_tp_order_filled(symbol) or realized_pnl > 0.5
                        symbol_position_state[symbol] = None
                        symbol_entry_price[symbol] = None
                        symbol_tp_order_id.pop(symbol, None)
                        if is_tp:
                            symbol_blocked_until_candle[symbol] = current_candle_open_ts + 8 * 3600
                            await send_telegram(f"✅ {current_side} TP Hit {symbol}\nNo more trades this 8h candle", silent=False)
                        continue

                    unrealized = float(pos.get("unRealizedProfit", 0))
                    notional_pos = abs(amt) * mark_price
                    unrealized_pct = (unrealized / notional_pos * 100) if notional_pos > 0 else 0

                    if unrealized_pct < -MAX_DRAWDOWN_PCT:
                        close_position(symbol, f"drawdown protection (-{MAX_DRAWDOWN_PCT}%)")
                        continue

                    if current_side == "LONG":
                        offset_high = day_open * (1 + OFFSET_PCT / 100.0)
                        if sma_current < offset_high and sma_prev >= offset_high:
                            close_position(symbol, f"Offset crossed down ({OFFSET_PCT}%)", update_state=False)
                            symbol_wait_for_reversal[symbol] = "LONG"
                            symbol_last_exit_time[symbol] = now_ts

                    elif current_side == "SHORT":
                        offset_low = day_open * (1 - OFFSET_PCT / 100.0)
                        if sma_current > offset_low and sma_prev <= offset_low:
                            close_position(symbol, f"Offset crossed up ({OFFSET_PCT}%)", update_state=False)
                            symbol_wait_for_reversal[symbol] = "SHORT"
                            symbol_last_exit_time[symbol] = now_ts

            except Exception as e:
                logger.error(f"[{symbol}] Error: {e}", exc_info=True)

        await asyncio.sleep(CHECK_INTERVAL_SECONDS)

