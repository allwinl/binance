# Trading loop - SMA Crossover Strategy
# ────────────────────────────────────────────────

async def trading_loop(_: Application) -> None:
    logger.info("Trading loop started – SMA(3) Crossover vs Previous Day Open + 20% Fixed TP")
    await send_telegram("Bot started • SMA(3) Crossover vs Prev Day Open + 20% Fixed TP", silent=False)

    while True:
        if not monitored_symbols:
            await asyncio.sleep(CHECK_INTERVAL_SECONDS)
            continue

        for symbol in list(monitored_symbols):
            try:
                sync_position_state(symbol)
                current_side = symbol_position_state.get(symbol)

                pos = get_current_position_data(symbol)
                if not pos and current_side is not None:
                    symbol_position_state[symbol] = None
                    symbol_entry_price[symbol] = None
                    continue

                if pos:
                    pnl = float(pos.get("unRealizedProfit", 0))
                    if MAX_ALLOWED_LOSS_USDT < 0 and pnl < MAX_ALLOWED_LOSS_USDT:
                        close_position(symbol, "max loss cut")
                        continue

                qty = calculate_safe_quantity(symbol)
                if qty < 1e-5:
                    continue

                # === Fetch klines ===
                klines_1d = get_klines(symbol, "1d", limit=2)
                klines_3m = get_klines(symbol, "3m", limit=30)   # Enough data for reliable SMA

                if len(klines_1d) < 2 or len(klines_3m) < 5:
                    continue

                # Previous day open price (last completed day)
                day_open = float(klines_1d[-2][1])

                # Calculate SMA(3) for the last few 3m candles
                closes = [float(k[4]) for k in klines_3m]  # all closes
                sma_values = []
                for i in range(2, len(closes)):
                    sma = sum(closes[i-2:i+1]) / 3
                    sma_values.append(sma)

                if len(sma_values) < 3:
                    continue

                # Get recent SMA values
                sma_current = sma_values[-1]   # sma[-1]  (most recent)
                sma_prev     = sma_values[-2]  # sma[-2]
                sma_prev2    = sma_values[-3]  # sma[-3]

                mark_price = get_current_price(symbol)
                if mark_price <= 0:
                    continue

                logger.info(f"[{symbol}] Day Open: {day_open:.4f} | SMA[-3]: {sma_prev2:.4f} | SMA[-2]: {sma_prev:.4f} | SMA[-1]: {sma_current:.4f}")

                can_trade = True
                if symbol in last_action_time and last_action_time[symbol]:
                    delta = datetime.now(timezone.utc) - last_action_time[symbol]
                    if delta < timedelta(seconds=COOLDOWN_SECONDS):
                        can_trade = False

                if not can_trade:
                    continue

                # ==================== ENTRY LOGIC ====================
                if current_side is None:
                    # Long: SMA crosses above day open
                    if sma_prev > day_open and sma_prev2 < day_open:
                        resp = place_market_order(symbol, "BUY", qty)
                        if resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED"):
                            symbol_position_state[symbol] = "LONG"
                            symbol_entry_price[symbol] = mark_price

                            tp_resp = place_take_profit_order(symbol, "LONG", qty, mark_price)
                            tp_price = mark_price * (1 + TAKE_PROFIT_PCT / 100.0)
                            tp_str = f"{tp_price:.{get_price_precision(symbol)}f}".rstrip("0").rstrip(".")

                            msg = f"🟢 LONG {symbol} @ {mark_price:.2f} (TP {tp_str}) | SMA Crossover Up"
                            logger.info(msg)
                            await send_telegram(msg, silent=False)
                            last_action_time[symbol] = datetime.now(timezone.utc)

                    # Short: SMA crosses below day open
                    elif sma_prev < day_open and sma_prev2 > day_open:
                        resp = place_market_order(symbol, "SELL", qty)
                        if resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED"):
                            symbol_position_state[symbol] = "SHORT"
                            symbol_entry_price[symbol] = mark_price

                            tp_resp = place_take_profit_order(symbol, "SHORT", qty, mark_price)
                            tp_price = mark_price * (1 - TAKE_PROFIT_PCT / 100.0)
                            tp_str = f"{tp_price:.{get_price_precision(symbol)}f}".rstrip("0").rstrip(".")

                            msg = f"🔴 SHORT {symbol} @ {mark_price:.2f} (TP {tp_str}) | SMA Crossover Down"
                            logger.info(msg)
                            await send_telegram(msg, silent=False)
                            last_action_time[symbol] = datetime.now(timezone.utc)

                # ==================== EXIT LOGIC (Opposite Crossover) ====================
                elif current_side == "LONG":
                    if sma_prev < day_open and sma_prev2 > day_open:
                        logger.info(f"[{symbol}] Opposite SMA crossover down → closing LONG")
                        close_position(symbol, "opposite crossover")

                elif current_side == "SHORT":
                    if sma_prev > day_open and sma_prev2 < day_open:
                        logger.info(f"[{symbol}] Opposite SMA crossover up → closing SHORT")
                        close_position(symbol, "opposite crossover")

            except Exception as e:
                logger.error(f"[{symbol}] Error: {e}", exc_info=True)

        await asyncio.sleep(CHECK_INTERVAL_SECONDS)

