def get_realized_pnl_for_symbol(symbol: str) -> Optional[float]:
    try:
        params = {"symbol": symbol, "limit": 50}
        trades = signed_request("GET", "/fapi/v1/userTrades", params)
        if not isinstance(trades, list):
            return None
        total = sum(float(t.get("realizedProfit", 0)) for t in trades)
        return round(total, 2)
    except Exception as e:
        logger.error(f"Failed to get realized PNL for {symbol}: {e}")
        return None

def close_position(symbol: str, reason: str = "manual") -> bool:
    pos = get_current_position_data(symbol)
    if not pos or abs(float(pos.get("positionAmt", "0"))) < POSITION_TOLERANCE:
        symbol_position_state[symbol] = None
        symbol_entry_price[symbol] = None
        return True

    cancel_all_orders(symbol)
    amt = float(pos.get("positionAmt", "0"))
    side = "SELL" if amt > 0 else "BUY"
    qty = abs(amt)

    resp = place_market_order(symbol, side, qty, reduce_only=True)
    success = resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED")

    if success:
        direction = "LONG" if amt > 0 else "SHORT"
        realized_pnl = get_realized_pnl_for_symbol(symbol)
        pnl_str = f"{realized_pnl:+.2f} USDT" if realized_pnl is not None else "N/A"

        logger.info(f"Closed {direction} {symbol} ({reason}) | Realized PNL: {pnl_str}")
        symbol_position_state[symbol] = None
        symbol_entry_price[symbol] = None
        symbol_last_exit_time[symbol] = time.time()
        symbol_last_entry_time[symbol] = 0

        asyncio.create_task(send_telegram(
            f"Closed {direction} {symbol} → {reason}\n"
            f"Realized PNL: **{pnl_str}**"
        ))
    else:
        logger.error(f"Close failed {symbol}: {resp}")
    return success

