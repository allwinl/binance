def get_current_candle_ts(now: datetime) -> float:
    hour = now.hour
    candle_hour = (hour // 8) * 8
    current_candle = now.replace(hour=candle_hour, minute=0, second=0, microsecond=0)
    return current_candle.timestamp()

def get_candle_amplitude(symbol: str, candle_open_ts: float) -> float:
    klines = get_klines(symbol, "8h", limit=20)
    for k in klines:
        k_open_ts = int(k[0]) / 1000.0
        if abs(k_open_ts - candle_open_ts) < 300:
            open_p = float(k[1])
            close_p = float(k[4])
            return round(abs((close_p - open_p) / open_p) * 100, 2) if open_p != 0 else 0.0
    return 0.0

async def get_highest_volatility_symbol(now: datetime) -> Optional[str]:
    symbols = get_all_perp_symbols()
    if not symbols:
        return None
    target_candle_ts = get_current_candle_ts(now)
    best_symbol = None
    best_amplitude = -1.0
    best_volume = 0.0

    for symbol in symbols:
        try:
            amp = get_candle_amplitude(symbol, target_candle_ts)
            volume = 0.0
            klines = get_klines(symbol, "8h", limit=20)
            for k in klines:
                if abs(int(k[0])/1000 - target_candle_ts) < 300:
                    volume = float(k[5])
                    break

            if amp > best_amplitude or (abs(amp - best_amplitude) < 0.1 and volume > best_volume * 1.1):
                best_amplitude = amp
                best_volume = volume
                best_symbol = symbol
            await asyncio.sleep(0.08)
        except Exception:
            continue

    if best_symbol:
        logger.info(f"SELECTED → {best_symbol} | Amplitude: {best_amplitude:.2f}%")
    return best_symbol

async def auto_symbol_selection_task():
    await send_telegram("🤖 Scanner Active - 8h Volatility Based", silent=False)
    
    while True:
        now = datetime.now(timezone.utc)
        should_scan = now.minute >= 45 and now.hour % 8 == 7

        if should_scan:
            new_symbol = await get_highest_volatility_symbol(now)
            if new_symbol:
                for old in list(monitored_symbols):
                    if old != new_symbol:
                        close_position(old, "switching")
                        monitored_symbols.discard(old)
                        symbol_position_state.pop(old, None)
                        symbol_entry_price.pop(old, None)
                        symbol_last_exit_time.pop(old, None)
                        symbol_candle_open_time.pop(old, None)
                        symbol_tradeable_from_candle.pop(old, None)
                        symbol_cumulative_realized_loss.pop(old, None)
                        symbol_realized_pnl_this_candle.pop(old, None)
                
                if new_symbol not in monitored_symbols:
                    if ensure_leverage_and_margin(new_symbol):
                        monitored_symbols.add(new_symbol)
                        symbol_position_state[new_symbol] = None
                        symbol_last_exit_time[new_symbol] = 0
                        symbol_candle_open_time[new_symbol] = 0
                        symbol_cumulative_realized_loss[new_symbol] = 0.0
                        symbol_realized_pnl_this_candle[new_symbol] = 0.0
                        
                        next_candle = now.replace(minute=0, second=0, microsecond=0) + timedelta(hours=1)
                        symbol_tradeable_from_candle[new_symbol] = next_candle.timestamp()
                        
                        amp = get_candle_amplitude(new_symbol, get_current_candle_ts(now))
                        await send_telegram(f"🔄 New symbol: **{new_symbol}**\nAmplitude: {amp:.2f}%", silent=False)
            
            await asyncio.sleep(8 * 3600 - 1800)
        else:
            await asyncio.sleep(30)

