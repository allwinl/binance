async def handle_alert_bot_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if update.effective_user.id != ALERT_BOT_USER_ID:
        return

    text = update.message.text.strip()
    if not text.startswith(("/add ", "/rem ")):
        return

    parts = text.split(maxsplit=1)
    if len(parts) < 2:
        return

    cmd = parts[0]
    symbol = parts[1].strip().upper()

    if cmd == "/add":
        await try_add_symbol(symbol, ALERT_BOT_USER_ID, None)
    elif cmd == "/rem":
        await try_remove_symbol(symbol, ALERT_BOT_USER_ID, None)

# ────────────────────────────────────────────────
# Trading loop – MODIFIED: raw RSI slope instead of smoothed
# ────────────────────────────────────────────────

async def trading_loop(_: Application) -> None:
    logger.info(f"Trading loop started – check every {CHECK_INTERVAL_SECONDS}s – trailing {TRAILING_CALLBACK_RATE}% MARK_PRICE")
    await send_telegram(
        f"Bot started • Entry: raw RSI(7) slope • Exit: HMA direction • Trailing: {TRAILING_CALLBACK_RATE}% (MARK_PRICE)",
        silent=False
    )

    while True:
        if not monitored_symbols:
            await asyncio.sleep(CHECK_INTERVAL_SECONDS)
            continue

        for symbol in list(monitored_symbols):
            try:
                sync_position_state(symbol)
                current_side = symbol_position_state.get(symbol)

                pos = get_current_position_data(symbol)
                if not pos and current_side is not None:
                    symbol_position_state[symbol] = None
                    symbol_entry_price[symbol] = None
                    continue

                if pos:
                    pnl = float(pos.get("unRealizedProfit", 0))
                    if pnl < MAX_ALLOWED_LOSS_USDT:
                        close_position(symbol, "max loss cut")
                        await send_telegram(f"⚠️ LOSS CUT {symbol}  PnL {pnl:.2f}")
                        continue

                qty = calculate_safe_quantity(symbol)
                if qty < 1e-5:
                    continue

                klines = get_klines(symbol, "3m", 150)
                if not klines or len(klines) < 60:
                    continue

                df = pd.DataFrame(klines, columns=[
                    "ot","open","high","low","close","vol","ct","qv","n","tbv","tqv","i"
                ])
                df["close"] = df["close"].astype(float)

                hma15 = hma(df["close"], 15)
                rsi   = RSIIndicator(hma15, window=7).rsi()   # ← RSI on HMA(15), not on close

                if len(rsi.dropna()) < 2:
                    continue
                    
                curr_rsi = rsi.iloc[-2]
                prev_rsi = rsi.iloc[-3]
                last_rsi = rsi.iloc[-4]

                curr_hma = hma15.iloc[-2]
                prev_hma = hma15.iloc[-3]
                last_hma = hma15.iloc[-4]

                if any(pd.isna(x) for x in [curr_rsi, prev_rsi, last_rsi, curr_hma, last_hma, prev_hma]):
                    continue

                mark_price = get_current_price(symbol)
                if mark_price <= 0:
                    continue

                momentum_up   = curr_rsi > prev_rsi and  prev_rsi < last_rsi
                momentum_down = curr_rsi < prev_rsi and  prev_rsi > last_rsi

                hma_down      = curr_hma < prev_hma and prev_hma > last_hma
                hma_up        = curr_hma > prev_hma and prev_hma < last_hma

                logger.info(f"[{symbol}] {mark_price:.4f} | "
                           f"HMA {curr_hma:.4f} ({'↑' if hma_up else '↓'}) | "
                           f"RSI(7) {curr_rsi:.2f} ({'↑' if momentum_up else '↓'})")

                can_trade = True
                if symbol in last_action_time and last_action_time[symbol]:
                    delta = datetime.now(timezone.utc) - last_action_time[symbol]
                    if delta < timedelta(seconds=COOLDOWN_SECONDS):
                        can_trade = False

                if not can_trade:
                    continue

                # ── No position → Entry (now using raw RSI slope) ───────────
                if current_side is None:
                    if momentum_up:
                        resp = place_market_order(symbol, "BUY", qty)
                        if resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED"):
                            symbol_position_state[symbol] = "LONG"
                            symbol_entry_price[symbol] = mark_price
                            trail_resp = place_trailing_stop_order(symbol, "LONG", qty, mark_price)

                            msg = f"🟢 LONG {symbol} @ {mark_price:.4f}  (trailing {TRAILING_CALLBACK_RATE}%)"
                            if isinstance(trail_resp, dict) and "algoOrderId" in trail_resp:
                                msg += f"  algoId {trail_resp['algoOrderId']}"
                            elif "error" in trail_resp or "code" in trail_resp:
                                msg += f"  [TRAIL FAILED: {trail_resp.get('msg', trail_resp.get('error'))}]"
                            logger.info(msg)
                            await send_telegram(msg, silent=False)
                            last_action_time[symbol] = datetime.now(timezone.utc)

                    elif momentum_down:
                        resp = place_market_order(symbol, "SELL", qty)
                        if resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED"):
                            symbol_position_state[symbol] = "SHORT"
                            symbol_entry_price[symbol] = mark_price
                            trail_resp = place_trailing_stop_order(symbol, "SHORT", qty, mark_price)

                            msg = f"🔴 SHORT {symbol} @ {mark_price:.4f}  (trailing {TRAILING_CALLBACK_RATE}%)"
                            if isinstance(trail_resp, dict) and "algoOrderId" in trail_resp:
                                msg += f"  algoId {trail_resp['algoOrderId']}"
                            elif "error" in trail_resp or "code" in trail_resp:
                                msg += f"  [TRAIL FAILED: {trail_resp.get('msg', trail_resp.get('error'))}]"
                            logger.info(msg)
                            await send_telegram(msg, silent=False)
                            last_action_time[symbol] = datetime.now(timezone.utc)

                # ── Has position → only check exit condition ───────────────
                elif current_side == "LONG":
                    if hma_down:
                        logger.info(f"[{symbol}] HMA ↓ → closing LONG")
                        close_position(symbol, "HMA down")
                        await send_telegram(f"Closed LONG {symbol} – HMA ↓")

                elif current_side == "SHORT":
                    if hma_up:
                        logger.info(f"[{symbol}] HMA ↑ → closing SHORT")
                        close_position(symbol, "HMA up")
                        await send_telegram(f"Closed SHORT {symbol} – HMA ↑")

            except Exception as e:
                logger.error(f"[{symbol}] Error: {e}", exc_info=True)

        await asyncio.sleep(CHECK_INTERVAL_SECONDS)

