async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    text = (
        "SMA(3) Crossover vs Previous Day Open Bot\n\n"
        "Long  : SMA[-2] > Day Open  AND  SMA[-3] < Day Open\n"
        "Short : SMA[-2] < Day Open  AND  SMA[-3] > Day Open\n"
        "Exit  : Opposite crossover\n"
        "TP    : Fixed 20%\n\n"
        "Commands:\n"
        "  /add SYMBOL\n"
        "  /rem SYMBOL\n"
        "  /list\n"
        "  /reset"
    )
    await update.message.reply_text(text)

async def cmd_list(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols are being monitored.")
        return
    lines = ["Monitored symbols:"]
    for sym in sorted(monitored_symbols):
        side = symbol_position_state.get(sym, "—")
        lines.append(f"  {sym:10}  {side}")
    await update.message.reply_text("\n".join(lines))

async def cmd_reset(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    closed = [sym for sym in list(monitored_symbols) if close_position(sym, "reset")]
    monitored_symbols.clear()
    symbol_position_state.clear()
    symbol_entry_price.clear()
    configured.clear()
    last_action_time.clear()
    text = "Full reset performed."
    if closed:
        text += f"\nClosed: {', '.join(closed)}"
    await update.message.reply_text(text)
    await send_telegram("Bot reset – no symbols monitored")

async def try_add_symbol(symbol: str, from_user_id: int, reply_func) -> None:
    symbol = symbol.strip().upper()
    if not symbol.endswith("USDT") or not symbol_is_valid_perp(symbol):
        if reply_func:
            await reply_func(f"Invalid symbol: {symbol}")
        return

    if symbol in monitored_symbols:
        if reply_func:
            await reply_func(f"{symbol} already monitored")
        return

    if ensure_leverage_and_margin(symbol):
        monitored_symbols.add(symbol)
        symbol_position_state[symbol] = None
        logger.info(f"Added {symbol}")
        if reply_func:
            await reply_func(f"Added {symbol}")
    else:
        if reply_func:
            await reply_func(f"Failed to configure {symbol}")

async def try_remove_symbol(symbol: str, from_user_id: int, reply_func) -> None:
    symbol = symbol.strip().upper()
    if symbol not in monitored_symbols:
        if reply_func:
            await reply_func(f"{symbol} not monitored")
        return

    closed = close_position(symbol, "remove")
    monitored_symbols.remove(symbol)
    symbol_position_state.pop(symbol, None)
    symbol_entry_price.pop(symbol, None)
    configured.discard(symbol)
    last_action_time.pop(symbol, None)

    logger.info(f"Removed {symbol}")
    if reply_func:
        await reply_func(f"Removed {symbol}")

async def cmd_add(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await update.message.reply_text("Usage: /add BTCUSDT")
        return
    await try_add_symbol(context.args[0], update.effective_user.id, update.message.reply_text)

async def cmd_rem(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await update.message.reply_text("Usage: /rem BTCUSDT")
        return
    await try_remove_symbol(context.args[0], update.effective_user.id, update.message.reply_text)

async def handle_alert_bot_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if update.effective_user.id != ALERT_BOT_USER_ID:
        return
    text = update.message.text.strip()
    if not text.startswith(("/add ", "/rem ")):
        return
    parts = text.split(maxsplit=1)
    if len(parts) < 2:
        return
    cmd = parts[0]
    symbol = parts[1].strip().upper()
    if cmd == "/add":
        await try_add_symbol(symbol, ALERT_BOT_USER_ID, None)
    elif cmd == "/rem":
        await try_remove_symbol(symbol, ALERT_BOT_USER_ID, None)

