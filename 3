def get_previous_candle_ts(now: datetime) -> float:
    """Return open timestamp of the PREVIOUS completed 8h candle"""
    hour = now.hour
    candle_hour = (hour // 8) * 8
    current_candle = now.replace(hour=candle_hour, minute=0, second=0, microsecond=0)

    if (now - current_candle).total_seconds() < 600:   # first 10 min of new candle
        current_candle -= timedelta(hours=8)

    previous_candle = current_candle - timedelta(hours=8)
    return previous_candle.timestamp()


def get_candle_amplitude(symbol: str, candle_open_ts: float) -> float:
    klines = get_klines(symbol, "8h", limit=20)
    for k in klines:
        k_open_ts = int(k[0]) / 1000.0
        if abs(k_open_ts - candle_open_ts) < 300:   # 5-minute tolerance
            open_p = float(k[1])
            close_p = float(k[4])
            if open_p == 0:
                return 0.0
            return round(abs((close_p - open_p) / open_p) * 100, 2)
    return 0.0


async def get_highest_volatility_symbol(now: datetime) -> Optional[str]:
    symbols = get_all_perp_symbols()
    if not symbols:
        logger.error("No perpetual USDT symbols fetched")
        return None

    target_candle_ts = get_previous_candle_ts(now)
    best_symbol = None
    best_amplitude = -1.0
    best_volume = 0.0
    top_results = []

    logger.info(f"Scanning {len(symbols)} USDT perpetual symbols for previous 8h candle...")

    for symbol in symbols:
        try:
            amp = get_candle_amplitude(symbol, target_candle_ts)

            # Get USDT volume for tie-breaker
            volume = 0.0
            klines = get_klines(symbol, "8h", limit=20)
            for k in klines:
                if abs(int(k[0])/1000 - target_candle_ts) < 300:
                    volume = float(k[5])
                    break

            if amp > best_amplitude or (abs(amp - best_amplitude) < 0.1 and volume > best_volume * 1.1):
                best_amplitude = amp
                best_volume = volume
                best_symbol = symbol

            # Keep top 5 for logging
            top_results.append((symbol, amp, volume))
            if len(top_results) > 5:
                top_results.sort(key=lambda x: x[1], reverse=True)
                top_results = top_results[:5]

            await asyncio.sleep(0.08)  # Rate limit safety

        except Exception:
            continue

    if best_symbol:
        logger.info(f"SELECTED → {best_symbol} | Amplitude: {best_amplitude:.2f}% | Volume: {best_volume:,.0f} USDT")
        logger.info("Top 5 most volatile symbols:")
        for sym, amp, vol in sorted(top_results, key=lambda x: x[1], reverse=True):
            logger.info(f"  {sym:12} → {amp:6.2f}%   Vol: {vol:,.0f} USDT")

    return best_symbol


