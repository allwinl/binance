async def trading_loop(_: Application) -> None:
    logger.info("Trading loop started - Dynamic TP + 5% Realized Profit Lock")
    await send_telegram("Bot started • Dynamic TP + 5% Realized Profit Lock per 8h candle", silent=False)

    while True:
        if not monitored_symbols:
            await asyncio.sleep(CHECK_INTERVAL_SECONDS)
            continue

        for symbol in list(monitored_symbols):
            try:
                sync_position_state(symbol)
                current_side = symbol_position_state.get(symbol)
                mark_price = get_current_price(symbol)
                qty = calculate_safe_quantity(symbol)
                if qty < 1e-5:
                    continue

                klines_8h = get_klines(symbol, "8h", limit=5)
                if len(klines_8h) < 2:
                    continue

                current_candle_open_ts = int(klines_8h[-1][0]) / 1000.0
                day_open = float(klines_8h[-1][1])

                if symbol_candle_open_time.get(symbol, 0) != current_candle_open_ts:
                    symbol_candle_open_time[symbol] = current_candle_open_ts
                    symbol_cumulative_realized_loss[symbol] = 0.0
                    symbol_realized_pnl_this_candle[symbol] = 0.0
                    logger.info(f"[{symbol}] New 8h candle started")

                now_ts = time.time()
                if now_ts - current_candle_open_ts < 60:
                    continue
                if current_candle_open_ts < symbol_tradeable_from_candle.get(symbol, 0) - 10:
                    continue

                # === Get Realized PNL from Binance ===
                realized_pnl = get_realized_pnl_this_candle(symbol, current_candle_open_ts)
                symbol_realized_pnl_this_candle[symbol] = realized_pnl

                notional = qty * mark_price
                profit_threshold = (PROFIT_LOCK_PCT / 100.0) * notional

                # === 5% Realized Profit Lock ===
                if realized_pnl >= profit_threshold:
                    if current_side is not None:
                        close_position(symbol, f"{PROFIT_LOCK_PCT}% realized profit lock reached", update_state=True)
                    logger.info(f"[{symbol}] {PROFIT_LOCK_PCT}% realized profit reached → No more new trades this candle")
                    continue

                # Update cumulative loss for dynamic TP
                current_loss = max(0.0, -realized_pnl)
                symbol_cumulative_realized_loss[symbol] = current_loss
                dynamic_tp = BASE_TP_PCT + (current_loss / notional * 100 if notional > 0 else 0)

                # 1m SMA
                klines_1m = get_klines(symbol, "1m", limit=30)
                if len(klines_1m) < 10:
                    continue
                closes = [float(k[4]) for k in klines_1m]
                sma_prev = sum(closes[-3:]) / 3

                in_safety = (now_ts - symbol_last_exit_time.get(symbol, 0)) < 2

                # === ENTRY ===
                if current_side is None and not in_safety:
                    if realized_pnl >= profit_threshold:
                        continue

                    if sma_prev > day_open:
                        resp = place_market_order(symbol, "BUY", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_position_state[symbol] = "LONG"
                            symbol_entry_price[symbol] = mark_price
                            await send_telegram(f"🟢 LONG {symbol} @ {mark_price:.2f} | TP: {dynamic_tp:.1f}%", silent=False)
                            place_take_profit_order(symbol, "BUY", mark_price, dynamic_tp, qty)

                    elif sma_prev < day_open:
                        resp = place_market_order(symbol, "SELL", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_position_state[symbol] = "SHORT"
                            symbol_entry_price[symbol] = mark_price
                            await send_telegram(f"🔴 SHORT {symbol} @ {mark_price:.2f} | TP: {dynamic_tp:.1f}%", silent=False)
                            place_take_profit_order(symbol, "SELL", mark_price, dynamic_tp, qty)

                # === EXIT LOGIC ===
                elif current_side is not None:
                    pos = get_current_position_data(symbol)
                    unrealized = float(pos.get("unRealizedProfit", 0))
                    unrealized_pct = (unrealized / notional * 100) if notional > 0 else 0

                    if unrealized_pct < -MAX_DRAWDOWN_PCT:
                        close_position(symbol, f"drawdown protection (-{MAX_DRAWDOWN_PCT}%)")

                    # Offset safety exit (do NOT update state to prevent immediate re-entry)
                    elif current_side == "LONG" and sma_prev < (day_open * (1 + OFFSET_PCT / 100.0)):
                        close_position(symbol, f"offset safety (+{OFFSET_PCT}%)", update_state=False)
                        symbol_last_exit_time[symbol] = time.time()

                    elif current_side == "SHORT" and sma_prev > (day_open * (1 - OFFSET_PCT / 100.0)):
                        close_position(symbol, f"offset safety (-{OFFSET_PCT}%)", update_state=False)
                        symbol_last_exit_time[symbol] = time.time()

                    # Normal exit on SMA crossing open price
                    elif (current_side == "LONG" and sma_prev < day_open) or \
                         (current_side == "SHORT" and sma_prev > day_open):
                        close_position(symbol, "SMA crossed open price")

            except Exception as e:
                logger.error(f"[{symbol}] Error: {e}", exc_info=True)

        await asyncio.sleep(CHECK_INTERVAL_SECONDS)

