async def get_highest_volatility_symbol(now: datetime) -> Optional[str]:
    all_symbols = get_all_perp_symbols()
    if not all_symbols:
        return None

    target = get_current_candle_ts(now)
    best_symbol = None
    best_amp = -1.0

    for symbol in all_symbols:
        try:
            df = get_historical_data(symbol, '8h', 20)
            if df is None or len(df) < 2:
                await asyncio.sleep(0.1)
                continue

            for idx in range(len(df)-1, -1, -1):
                candle_ts = df.index[idx].timestamp()
                if abs(candle_ts - target) < 300:
                    open_p = float(df['Open'].iloc[idx])
                    close_p = float(df['Close'].iloc[idx])
                    amp = round(abs((close_p - open_p) / open_p) * 100, 2) if open_p != 0 else 0.0
                    if amp > best_amp:
                        best_amp = amp
                        best_symbol = symbol
                    break
            await asyncio.sleep(0.08)
        except:
            continue

    if best_symbol:
        logger.info(f"SELECTED → {best_symbol} | Amplitude: {best_amp:.2f}%")
    return best_symbol


async def auto_symbol_selection_task():
    await send_telegram("🤖 Scanner Active - 8h Amplitude (Meme & Alpha Excluded)", silent=False)
    while True:
        now = datetime.now(timezone.utc)
        should_scan = now.minute >= 45 and now.hour % 8 == 7
        if should_scan:
            new_symbol = await get_highest_volatility_symbol(now)
            if new_symbol:
                for old in list(monitored_symbols):
                    if old != new_symbol:
                        close_position(old, "switching")
                        monitored_symbols.discard(old)
                if new_symbol not in monitored_symbols:
                    if ensure_leverage_and_margin(new_symbol):
                        monitored_symbols.add(new_symbol)
                        symbol_position_state[new_symbol] = None
                        symbol_last_exit_time[new_symbol] = 0
                        symbol_last_safety_exit_time[new_symbol] = 0
                        symbol_candle_open_time[new_symbol] = 0
                        symbol_cumulative_realized_loss[new_symbol] = 0.0
                        symbol_realized_pnl_this_candle[new_symbol] = 0.0
                        symbol_last_direction[new_symbol] = None
                        symbol_locked_until_candle.pop(new_symbol, None)
                        next_candle = now.replace(minute=0, second=0, microsecond=0) + timedelta(hours=1)
                        symbol_tradeable_from_candle[new_symbol] = next_candle.timestamp()
                        await send_telegram(f"🔄 New symbol: **{new_symbol}**", silent=False)
            await asyncio.sleep(8 * 3600 - 1800)
        else:
            await asyncio.sleep(30)


