async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await update.message.reply_text("Dynamic TP Bot\nCommands: /add /rem /list /status /reset")

async def cmd_list(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols monitored.")
        return
    lines = ["Monitored symbols:"]
    for sym in sorted(monitored_symbols):
        side = symbol_position_state.get(sym, "—")
        lines.append(f"  {sym:10}  {side}")
    await update.message.reply_text("\n".join(lines))

async def cmd_status(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols monitored.")
        return
    lines = ["📊 **Bot Status**"]
    for sym in sorted(monitored_symbols):
        realized = symbol_realized_pnl_this_candle.get(sym, 0.0)
        loss = symbol_cumulative_realized_loss.get(sym, 0.0)
        side = symbol_position_state.get(sym, "None")
        locked = " 🔒Locked" if sym in symbol_locked_until_candle else ""
        lines.append(f"**{sym}** | Realized: {realized:.2f} | Loss: {loss:.2f} | Pos: {side}{locked}")
    await update.message.reply_text("\n".join(lines), parse_mode="Markdown")

async def try_add_symbol(symbol: str, reply_func=None):
    symbol = symbol.strip().upper()
    if not symbol.endswith("USDT") or symbol not in get_all_perp_symbols():
        if reply_func: await reply_func(f"Invalid symbol: {symbol}")
        return
    if symbol in monitored_symbols:
        if reply_func: await reply_func(f"{symbol} already monitored")
        return
    if ensure_leverage_and_margin(symbol):
        monitored_symbols.add(symbol)
        symbol_position_state[symbol] = None
        symbol_last_exit_time[symbol] = 0
        symbol_last_safety_exit_time[symbol] = 0
        symbol_candle_open_time[symbol] = 0
        symbol_cumulative_realized_loss[symbol] = 0.0
        symbol_realized_pnl_this_candle[symbol] = 0.0
        symbol_last_direction[symbol] = None
        symbol_locked_until_candle.pop(symbol, None)
        if reply_func: await reply_func(f"✅ Added {symbol}")

async def try_remove_symbol(symbol: str, reply_func=None):
    symbol = symbol.strip().upper()
    if symbol not in monitored_symbols:
        if reply_func: await reply_func(f"{symbol} not monitored")
        return
    close_position(symbol, "remove")
    monitored_symbols.remove(symbol)
    symbol_position_state.pop(symbol, None)
    symbol_entry_price.pop(symbol, None)
    symbol_last_exit_time.pop(symbol, None)
    symbol_last_safety_exit_time.pop(symbol, None)
    symbol_candle_open_time.pop(symbol, None)
    symbol_tradeable_from_candle.pop(symbol, None)
    symbol_cumulative_realized_loss.pop(symbol, None)
    symbol_realized_pnl_this_candle.pop(symbol, None)
    symbol_last_direction.pop(symbol, None)
    symbol_locked_until_candle.pop(symbol, None)
    configured.discard(symbol)
    if reply_func: await reply_func(f"✅ Removed {symbol}")

