async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    text = (
        "Momentum bot – raw RSI slope entry\n"
        "LONG entry:  RSI(7) ↑\n"
        "SHORT entry: RSI(7) ↓\n"
        "Exit LONG:   HMA ↓\n"
        "Exit SHORT:  HMA ↑\n"
        f"Trailing:    {TRAILING_CALLBACK_RATE}% callback (MARK_PRICE)\n\n"
        "Commands:\n"
        "  /add SYMBOL     – add symbol\n"
        "  /rem SYMBOL     – remove symbol\n"
        "  /list           – show monitored symbols\n"
        "  /reset          – clear everything\n"
    )
    await update.message.reply_text(text)

async def cmd_list(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols are being monitored.")
        return
    lines = ["Monitored symbols:"]
    for sym in sorted(monitored_symbols):
        side = symbol_position_state.get(sym, "—")
        lines.append(f"  {sym:10}  {side}")
    await update.message.reply_text("\n".join(lines))

async def cmd_reset(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    closed = [sym for sym in list(monitored_symbols) if close_position(sym, "reset")]
    old = sorted(monitored_symbols)
    monitored_symbols.clear()
    symbol_position_state.clear()
    symbol_entry_price.clear()
    configured.clear()
    last_action_time.clear()
    text = "Full reset performed.\n"
    if old:
        text += f"Removed: {', '.join(old)}\n"
    if closed:
        text += f"Closed: {', '.join(closed)}\n"
    await update.message.reply_text(text)
    await send_telegram("Bot reset – no symbols monitored")

