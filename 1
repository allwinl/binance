def get_all_perp_symbols() -> List[str]:
    url = "https://fapi.binance.com/fapi/v1/exchangeInfo"
    try:
        response = requests.get(url, timeout=15)
        response.raise_for_status()
        data = response.json()

        excluded_subtypes = {"Meme", "Alpha"}
        symbols = []

        for s in data.get('symbols', []):
            if (s.get('quoteAsset') == 'USDT' and 
                s.get('status') == 'TRADING' and 
                s.get('contractType') == 'PERPETUAL'):
                
                subtype = s.get('underlyingSubType')
                
                # Fixed: Handle both string and list
                skip = False
                if isinstance(subtype, list):
                    if any(item in excluded_subtypes for item in subtype):
                        skip = True
                elif isinstance(subtype, str):
                    if subtype in excluded_subtypes:
                        skip = True
                
                if not skip:
                    symbols.append(s['symbol'])

        logger.info(f"Loaded {len(symbols)} USDT Perpetual symbols (Meme & Alpha excluded)")
        return symbols
    except Exception as e:
        logger.error(f"Error fetching symbols: {e}")
        return []


