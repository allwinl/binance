async def trading_loop(_: Application) -> None:
    logger.info("Trading loop started")
    await send_telegram("Bot started in TESTNET • Full symbol scan + improved logic", silent=False)

    while True:
        if not monitored_symbols:
            await asyncio.sleep(CHECK_INTERVAL_SECONDS)
            continue

        for symbol in list(monitored_symbols):
            try:
                sync_position_state(symbol)
                current_side = symbol_position_state.get(symbol)
                mark_price = get_current_price(symbol)

                pos = get_current_position_data(symbol)
                if pos and MAX_ALLOWED_LOSS_USDT < 0:
                    pnl = float(pos.get("unRealizedProfit", 0))
                    if pnl < MAX_ALLOWED_LOSS_USDT:
                        close_position(symbol, "max loss cut")
                        continue

                qty = calculate_safe_quantity(symbol)
                if qty < 1e-5:
                    continue

                klines_8h = get_klines(symbol, "8h", limit=5)
                if len(klines_8h) < 2:
                    continue

                current_candle_open_ts = int(klines_8h[-1][0]) / 1000.0

                if symbol_candle_open_time.get(symbol, 0) != current_candle_open_ts:
                    symbol_candle_open_time[symbol] = current_candle_open_ts
                    logger.info(f"[{symbol}] New candle opened")

                now_ts = time.time()
                if now_ts - current_candle_open_ts < 60:
                    continue

                tradeable_from = symbol_tradeable_from_candle.get(symbol, 0)
                if current_candle_open_ts < tradeable_from - 10:
                    continue

                day_open = float(klines_8h[-1][1])
                klines_1m = get_klines(symbol, "1m", limit=30)
                if len(klines_1m) < 10:
                    continue

                closes = [float(k[4]) for k in klines_1m]
                sma_values = [sum(closes[i-2:i+1])/3 for i in range(2, len(closes))]
                if len(sma_values) < 3:
                    continue
                sma_prev = sma_values[-2]

                in_safety = (now_ts - symbol_last_exit_time.get(symbol, 0)) < POST_TP_SAFETY_SECONDS

                if current_side is None and not in_safety:
                    if sma_prev > day_open:
                        resp = place_market_order(symbol, "BUY", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_position_state[symbol] = "LONG"
                            symbol_entry_price[symbol] = mark_price
                            place_take_profit_order(symbol, "LONG", qty, mark_price)
                            await send_telegram(f"🟢 LONG {symbol} @ {mark_price:.2f} (TP {TAKE_PROFIT_PCT}%)", silent=False)
                    elif sma_prev < day_open:
                        resp = place_market_order(symbol, "SELL", qty)
                        if resp.get("status") in ("NEW", "FILLED"):
                            symbol_position_state[symbol] = "SHORT"
                            symbol_entry_price[symbol] = mark_price
                            place_take_profit_order(symbol, "SHORT", qty, mark_price)
                            await send_telegram(f"🔴 SHORT {symbol} @ {mark_price:.2f} (TP {TAKE_PROFIT_PCT}%)", silent=False)

                elif current_side == "LONG" and sma_prev < day_open:
                    close_position(symbol, "opposite SMA signal")
                elif current_side == "SHORT" and sma_prev > day_open:
                    close_position(symbol, "opposite SMA signal")

            except Exception as e:
                logger.error(f"[{symbol}] Error: {e}", exc_info=True)

        await asyncio.sleep(CHECK_INTERVAL_SECONDS)

