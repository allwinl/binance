async def auto_symbol_selection_task():
    await send_telegram("🤖 8h Volatility Scanner Active\nScans at 23:45 | 07:45 | 15:45 UTC", silent=False)
    while True:
        now = datetime.now(timezone.utc)
        h, m = now.hour, now.minute
        should_scan = (h == 16 and m >= 40) or (h == 7 and m >= 45) or (h == 15 and m >= 45)

        if should_scan:
            logger.info(f"Volatility scan at {now.strftime('%H:%M UTC')}")
            new_symbol = get_highest_volatility_symbol()
            if new_symbol:
                for old in list(monitored_symbols):
                    if old != new_symbol:
                        close_position(old, "switching to new volatile symbol")
                        monitored_symbols.discard(old)
                        symbol_position_state.pop(old, None)
                        symbol_entry_price.pop(old, None)
                        symbol_last_exit_time.pop(old, None)
                        symbol_candle_start_time.pop(old, None)
                if new_symbol not in monitored_symbols:
                    if ensure_leverage_and_margin(new_symbol):
                        monitored_symbols.add(new_symbol)
                        symbol_position_state[new_symbol] = None
                        symbol_last_exit_time[new_symbol] = 0
                        symbol_candle_start_time[new_symbol] = 0
                        await send_telegram(f"🔄 New volatile symbol selected:\n**{new_symbol}**\nWaiting for new 8h candle to open...", silent=False)
            await asyncio.sleep(8 * 3600 - 900)
        else:
            await asyncio.sleep(60)

