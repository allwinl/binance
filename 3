async def send_telegram(msg: str, silent: bool = True):
    try:
        await telegram_bot.send_message(chat_id=TELEGRAM_CHAT_ID, text=msg, disable_notification=silent)
    except Exception as e:
        logger.error(f"Telegram send failed: {e}")

def signed_request(method: str, endpoint: str, params: Dict = None) -> dict:
    if params is None: params = {}
    params["timestamp"] = int(time.time() * 1000)
    params["recvWindow"] = 5000
    qs = urlencode(sorted(params.items()))
    sig = hmac.new(API_SECRET.encode(), qs.encode(), hashlib.sha256).hexdigest()
    url = f"{BASE_URL}{endpoint}?{qs}&signature={sig}"
    try:
        if method.upper() == "GET":
            r = requests.get(url, headers=HEADERS, timeout=10)
        elif method.upper() == "POST":
            r = requests.post(url, headers=HEADERS, timeout=10)
        elif method.upper() == "DELETE":
            r = requests.delete(url, headers=HEADERS, timeout=10)
        r.raise_for_status()
        return r.json()
    except Exception as e:
        logger.error(f"Request failed {endpoint}: {e}")
        return {"error": str(e)}

def public_get(endpoint: str, params: Dict = None):
    if params is None: params = {}
    try:
        r = requests.get(f"{BASE_URL}{endpoint}", params=params, timeout=10)
        r.raise_for_status()
        return r.json()
    except Exception as e:
        logger.error(f"Public GET failed {endpoint}: {e}")
        return {}

def get_filtered_perp_symbols() -> List[str]:
    data = public_get("/fapi/v1/exchangeInfo")
    filtered = []
    exclude = {"chinese", "china", "meme", "memecoin", "alpha"}
    for s in data.get("symbols", []):
        if s.get("contractType") != "PERPETUAL" or s.get("status") != "TRADING" or s.get("quoteAsset") != "USDT":
            continue
        sub_types = [str(x).lower() for x in s.get("underlyingSubType", [])]
        if any(k in sub_types for k in exclude):
            continue
        if any(k in s["symbol"].lower() for k in exclude):
            continue
        filtered.append(s["symbol"])
    return filtered

def get_price_precision(symbol: str) -> int:
    if symbol in _price_precision_cache: return _price_precision_cache[symbol]
    data = public_get("/fapi/v1/exchangeInfo")
    for s in data.get("symbols", []):
        if s["symbol"] == symbol:
            for f in s.get("filters", []):
                if f["filterType"] == "PRICE_FILTER":
                    tick = float(f.get("tickSize", "0.0001"))
                    prec = max(0, -int(math.log10(tick))) if tick > 0 else 4
                    _price_precision_cache[symbol] = prec
                    return prec
    return 4

def get_qty_step(symbol: str) -> float:
    if symbol in _qty_step_cache: return _qty_step_cache[symbol]
    data = public_get("/fapi/v1/exchangeInfo")
    for s in data.get("symbols", []):
        if s["symbol"] == symbol:
            for f in s.get("filters", []):
                if f["filterType"] == "LOT_SIZE":
                    step = float(f.get("stepSize", 0.001))
                    _qty_step_cache[symbol] = step
                    return step
    return 0.001

def ensure_leverage_and_margin(symbol: str) -> bool:
    if symbol in configured: return True
    pos_data = signed_request("GET", "/fapi/v2/positionRisk", {"symbol": symbol})
    if not isinstance(pos_data, list) or not pos_data: return False
    pos = pos_data[0]
    success = True
    if int(pos.get("leverage", 0)) != FIXED_LEVERAGE:
        r = signed_request("POST", "/fapi/v1/leverage", {"symbol": symbol, "leverage": FIXED_LEVERAGE})
        success &= "code" not in r or r["code"] >= 0
    if pos.get("isolated", False) != (FIXED_MARGIN_TYPE == "ISOLATED"):
        r = signed_request("POST", "/fapi/v1/marginType", {"symbol": symbol, "marginType": FIXED_MARGIN_TYPE})
        success &= "code" not in r or r["code"] >= 0
    if success:
        configured.add(symbol)
    return success

def get_current_position_data(symbol: str) -> dict:
    data = signed_request("GET", "/fapi/v2/positionRisk", {"symbol": symbol})
    return data[0] if isinstance(data, list) and data else {}

def sync_position_state(symbol: str) -> None:
    pos = get_current_position_data(symbol)
    amt = float(pos.get("positionAmt", "0"))
    real_side = "LONG" if amt > 0 else "SHORT" if amt < 0 else None
    if real_side != symbol_position_state.get(symbol):
        symbol_position_state[symbol] = real_side
        if real_side is None:
            symbol_entry_price[symbol] = None

def get_current_price(symbol: str) -> float:
    data = public_get("/fapi/v1/premiumIndex", {"symbol": symbol})
    return float(data.get("markPrice", 0)) if isinstance(data, dict) else 0.0

def get_klines(symbol: str, interval: str, limit: int = 200) -> list:
    try:
        r = requests.get(f"{BASE_URL}/fapi/v1/klines", params={
            "symbol": symbol, "interval": interval, "limit": limit
        }, timeout=12)
        r.raise_for_status()
        return r.json()
    except:
        return []

def calculate_safe_quantity(symbol: str) -> float:
    price = get_current_price(symbol)
    if price <= 0: return 0.0
    step_size = get_qty_step(symbol)
    target_usdt = 100
    raw_qty = target_usdt / price
    steps = math.ceil(raw_qty / step_size)
    qty = max(steps * step_size, step_size)
    return round(qty, 6)

def place_market_order(symbol: str, side: str, qty: float, reduce_only: bool = False) -> dict:
    if qty <= 0: return {"error": "Invalid qty"}
    qstr = f"{qty:.6f}".rstrip("0").rstrip(".")
    params = {"symbol": symbol, "side": side.upper(), "type": "MARKET", "quantity": qstr}
    if reduce_only: params["reduceOnly"] = "true"
    return signed_request("POST", "/fapi/v1/order", params)

def place_take_profit_order(symbol: str, position_side: str, entry_price: float, tp_percent: float, qty: float) -> dict:
    if qty <= 0 or entry_price <= 0: return {"error": "Invalid params"}
    price_prec = get_price_precision(symbol)
    if position_side.upper() == "BUY":
        tp_side, tp_price = "SELL", entry_price * (1 + tp_percent / 100.0)
    else:
        tp_side, tp_price = "BUY", entry_price * (1 - tp_percent / 100.0)
    tp_str = f"{tp_price:.{price_prec}f}".rstrip("0").rstrip(".")
    qstr = f"{qty:.6f}".rstrip("0").rstrip(".")
    params = {"symbol": symbol, "side": tp_side, "type": "LIMIT", "quantity": qstr,
              "price": tp_str, "timeInForce": "GTC", "reduceOnly": "true"}
    response = signed_request("POST", "/fapi/v1/order", params)
    if isinstance(response, dict) and response.get("orderId"):
        symbol_tp_order_id[symbol] = str(response["orderId"])
    return response

def cancel_all_orders(symbol: str):
    signed_request("DELETE", "/fapi/v1/allOpenOrders", {"symbol": symbol})
    time.sleep(0.4)

def close_position(symbol: str, reason: str = "manual", update_state: bool = True) -> bool:
    pos = get_current_position_data(symbol)
    amt = float(pos.get("positionAmt", "0"))
    if abs(amt) < POSITION_TOLERANCE:
        if update_state:
            symbol_position_state[symbol] = None
            symbol_entry_price[symbol] = None
        return True
    cancel_all_orders(symbol)
    time.sleep(0.3)
    side = "SELL" if amt > 0 else "BUY"
    qty = abs(amt)
    resp = place_market_order(symbol, side, qty, reduce_only=True)
    success = isinstance(resp, dict) and resp.get("status") in ("NEW", "FILLED", "PARTIALLY_FILLED")
    if success and update_state:
        direction = "LONG" if amt > 0 else "SHORT"
        asyncio.create_task(send_telegram(f"Closed {direction} {symbol} → {reason}", silent=False))
        symbol_position_state[symbol] = None
        symbol_entry_price[symbol] = None
        symbol_last_exit_time[symbol] = time.time()
    return success

def was_tp_order_filled(symbol: str) -> bool:
    if symbol not in symbol_tp_order_id: return False
    try:
        order = signed_request("GET", "/fapi/v1/order", {"symbol": symbol, "orderId": symbol_tp_order_id[symbol]})
        return isinstance(order, dict) and order.get("status") == "FILLED"
    except:
        return False

def get_realized_pnl_this_candle(symbol: str, candle_open_ts: float) -> float:
    start_time_ms = int(candle_open_ts * 1000)
    realized = 0.0
    income_data = signed_request("GET", "/fapi/v1/income", {
        "symbol": symbol, "incomeType": "REALIZED_PNL", "startTime": start_time_ms, "limit": 200
    })
    if isinstance(income_data, list):
        for item in income_data:
            if item.get("incomeType") == "REALIZED_PNL":
                realized += float(item.get("income", 0.0))
    return realized

def get_candle_amplitude(symbol: str, candle_open_ts: float) -> float:
    klines = get_klines(symbol, "8h", limit=20)
    for k in klines:
        k_open_ts = int(k[0]) / 1000.0
        if abs(k_open_ts - candle_open_ts) < 300:
            open_p = float(k[1])
            close_p = float(k[4])
            return round(abs((close_p - open_p) / open_p) * 100, 2) if open_p != 0 else 0.0
    return 0.0

def get_current_candle_ts(now: datetime) -> float:
    hour = now.hour
    candle_hour = (hour // 8) * 8
    current_candle = now.replace(hour=candle_hour, minute=0, second=0, microsecond=0)
    return current_candle.timestamp()

# Auto Symbol Selection
async def get_highest_volatility_symbol(now: datetime) -> Optional[str]:
    symbols = get_filtered_perp_symbols()
    if not symbols: return None
    target = get_current_candle_ts(now)
    best_symbol = None
    best_amp = -1.0
    for symbol in symbols:
        try:
            amp = get_candle_amplitude(symbol, target)
            if amp > best_amp:
                best_amp = amp
                best_symbol = symbol
            await asyncio.sleep(0.06)
        except:
            continue
    return best_symbol

async def auto_symbol_selection_task():
    await send_telegram("🤖 Scanner Active - Filtered", silent=False)
    while True:
        now = datetime.now(timezone.utc)
        should_scan = now.minute >= 45 and now.hour % 8 == 7
        if should_scan:
            new_symbol = await get_highest_volatility_symbol(now)
            if new_symbol and new_symbol not in monitored_symbols:
                if ensure_leverage_and_margin(new_symbol):
                    monitored_symbols.add(new_symbol)
                    symbol_entry_count_this_candle[new_symbol] = 0
                    await send_telegram(f"🔄 New symbol: **{new_symbol}**", silent=False)
            await asyncio.sleep(8 * 3600 - 1800)
        else:
            await asyncio.sleep(30)

