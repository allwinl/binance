async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await update.message.reply_text("Dynamic TP Bot\nCommands: /add /rem /list /status /reset")

async def cmd_list(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols monitored.")
        return
    lines = ["Monitored symbols:"]
    for sym in sorted(monitored_symbols):
        side = symbol_position_state.get(sym, "—")
        lines.append(f"  {sym:10}  {side}")
    await update.message.reply_text("\n".join(lines))

async def cmd_status(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not monitored_symbols:
        await update.message.reply_text("No symbols monitored.")
        return
    lines = ["📊 **Bot Status**"]
    for sym in sorted(monitored_symbols):
        blocked = "Yes" if sym in symbol_blocked_until_candle else "No"
        lines.append(f"**{sym}** | Blocked: {blocked}")
    await update.message.reply_text("\n".join(lines), parse_mode="Markdown")

async def cmd_reset(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    for sym in list(monitored_symbols):
        close_position(sym, "reset")
    monitored_symbols.clear()
    for d in [symbol_position_state, symbol_entry_price, symbol_last_exit_time, symbol_last_entry_time,
              symbol_wait_for_reversal, symbol_candle_open_time, symbol_tradeable_from_candle,
              symbol_cumulative_realized_loss, symbol_realized_pnl_this_candle, symbol_tp_order_id,
              symbol_blocked_until_candle, symbol_entry_count_this_candle]:
        d.clear()
    configured.clear()
    await update.message.reply_text("Full reset performed.")

async def try_add_symbol(symbol: str, reply_func=None):
    symbol = symbol.strip().upper()
    if not symbol.endswith("USDT") or symbol not in get_filtered_perp_symbols():
        if reply_func: await reply_func(f"Invalid or filtered: {symbol}")
        return
    if symbol in monitored_symbols:
        if reply_func: await reply_func(f"{symbol} already monitored")
        return
    if ensure_leverage_and_margin(symbol):
        monitored_symbols.add(symbol)
        symbol_entry_count_this_candle[symbol] = 0
        if reply_func: await reply_func(f"Added {symbol}")

async def try_remove_symbol(symbol: str, reply_func=None):
    symbol = symbol.strip().upper()
    if symbol not in monitored_symbols:
        if reply_func: await reply_func(f"{symbol} not monitored")
        return
    close_position(symbol, "remove")
    monitored_symbols.remove(symbol)
    for d in [symbol_position_state, symbol_entry_price, symbol_last_exit_time, symbol_last_entry_time,
              symbol_wait_for_reversal, symbol_candle_open_time, symbol_tradeable_from_candle,
              symbol_cumulative_realized_loss, symbol_realized_pnl_this_candle, symbol_tp_order_id,
              symbol_blocked_until_candle, symbol_entry_count_this_candle]:
        d.pop(symbol, None)
    configured.discard(symbol)
    if reply_func: await reply_func(f"Removed {symbol}")

async def cmd_add(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await update.message.reply_text("Usage: /add BTCUSDT")
        return
    await try_add_symbol(context.args[0], update.message.reply_text)

async def cmd_rem(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await update.message.reply_text("Usage: /rem BTCUSDT")
        return
    await try_remove_symbol(context.args[0], update.message.reply_text)

async def on_startup(app: Application) -> None:
    asyncio.create_task(trading_loop(app))
    asyncio.create_task(auto_symbol_selection_task())

